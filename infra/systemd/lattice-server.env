# Lattice Server environment variables
# This file is read by lattice-server.service via EnvironmentFile=
# Copy to /etc/lattice/server.env and adjust for your deployment.

# Logging level: error, warn, info, debug, trace
# Use comma-separated directives for per-module control:
#   RUST_LOG=info,lattice_quorum=debug,lattice_scheduler=debug
RUST_LOG=info

# Override gRPC listen address (default: from config file)
# LATTICE_API_GRPC_ADDRESS=0.0.0.0:50051

# Override REST listen address (default: from config file)
# LATTICE_API_REST_ADDRESS=0.0.0.0:8080

# Override quorum node ID (default: from config file)
# LATTICE_QUORUM_NODE_ID=1

# TSDB endpoint for telemetry push
# LATTICE_TELEMETRY_TSDB_ENDPOINT=http://victoriametrics:8428

# OIDC issuer URL for token validation
# LATTICE_API_OIDC_ISSUER=https://auth.example.com

# TLS configuration
# LATTICE_TLS_CERT=/etc/lattice/tls/server.crt
# LATTICE_TLS_KEY=/etc/lattice/tls/server.key
