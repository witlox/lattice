# Lattice Agent environment variables
# This file is read by lattice-agent.service via EnvironmentFile=
# Copy to /etc/lattice/agent.env and adjust for your deployment.

# Logging level
RUST_LOG=info

# Quorum endpoint(s) to connect to
# Comma-separated for multiple quorum members
LATTICE_QUORUM_ENDPOINT=http://lattice-server-1:50051

# ── Authentication ────────────────────────────────────────
# The agent authenticates to lattice-server via one of:
#
# 1. mTLS (production) — SPIRE SVID or bootstrap certs.
#    Set LATTICE_BOOTSTRAP_CERT/KEY/CA for bootstrap path.
#    SPIRE path uses the socket at LATTICE_SPIRE_SOCKET.
#
# 2. Bearer token (dev/testing/break-glass) — HMAC-signed JWT.
#    Set LATTICE_AGENT_TOKEN when no mTLS certs are available.
#
# mTLS takes priority. Token auth is the fallback.

# SPIRE agent socket (default: /run/spire/agent.sock)
# LATTICE_SPIRE_SOCKET=/run/spire/agent.sock

# Bootstrap certificates for mTLS (PEM files)
# LATTICE_BOOTSTRAP_CERT=/etc/lattice/tls/agent.crt
# LATTICE_BOOTSTRAP_KEY=/etc/lattice/tls/agent.key
# LATTICE_BOOTSTRAP_CA=/etc/lattice/tls/ca.crt

# Bearer token fallback (dev/testing/break-glass only)
# LATTICE_AGENT_TOKEN=eyJ...

# Heartbeat interval in seconds (default: 10)
# LATTICE_HEARTBEAT_INTERVAL=10

# GPU type on this node (e.g., GH200, MI300X, A100)
# Auto-detected via NVML if not set
# LATTICE_GPU_TYPE=GH200

# Override CPU core count (auto-detected if not set)
# LATTICE_CPU_CORES=64

# Override memory in GB (auto-detected if not set)
# LATTICE_MEMORY_GB=512

# eBPF programs directory
# LATTICE_EBPF_PROGRAMS_PATH=/opt/lattice/ebpf

# uenv image cache directory
# LATTICE_UENV_CACHE_PATH=/var/cache/lattice/uenv

# Local scratch path for checkpoints and temporary data
# LATTICE_LOCAL_SCRATCH=/scratch
